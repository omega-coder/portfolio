---
interface Props {
  title: string;
  description: string;
  tags: string[];
  github?: string;
  demo?: string;
  category: string;
  featured?: boolean;
}

const { title, description, tags, github, demo, category, featured = false } = Astro.props;

const categoryColors: Record<string, { bg: string; text: string; border: string }> = {
  security: { bg: '#00ff8815', text: '#00ff88', border: '#00ff8840' },
  devops: { bg: '#00d4ff15', text: '#00d4ff', border: '#00d4ff40' },
  cloud: { bg: '#fbbf2415', text: '#fbbf24', border: '#fbbf2440' },
  ctf: { bg: '#a855f715', text: '#a855f7', border: '#a855f740' },
  tools: { bg: '#f9731615', text: '#f97316', border: '#f9731640' },
};

const colors = categoryColors[category] ?? categoryColors.tools;
---

<div
  class:list={[
    'group relative rounded-xl border card-hover overflow-hidden',
    featured ? 'border-[#00ff8830]' : 'border-[#2a2a4a]',
  ]}
  style={`background: #0f0f1e; ${featured ? 'box-shadow: 0 0 30px rgba(0,255,136,0.05);' : ''}`}
>
  <!-- Featured indicator -->
  {featured && (
    <div class="absolute top-0 left-0 right-0 h-px"
         style="background: linear-gradient(90deg, transparent, #00ff88, transparent);">
    </div>
  )}

  <div class="p-6">
    <!-- Header -->
    <div class="flex items-start justify-between gap-3 mb-3">
      <div>
        <!-- Category badge -->
        <span
          class="font-mono text-xs px-2 py-0.5 rounded border mb-2 inline-block"
          style={`background: ${colors.bg}; color: ${colors.text}; border-color: ${colors.border};`}
        >
          {category}
        </span>
        <h3 class="font-mono font-bold text-[#e2e8f0] text-base group-hover:text-[#00ff88] transition-colors">
          {title}
        </h3>
      </div>

      <!-- Links -->
      <div class="flex items-center gap-2 shrink-0">
        {github && (
          <a
            href={github}
            target="_blank"
            rel="noopener noreferrer"
            class="text-[#4a4a6a] hover:text-[#00ff88] transition-colors"
            aria-label="GitHub repository"
            onclick="event.stopPropagation()"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
          </a>
        )}
        {demo && (
          <a
            href={demo}
            target="_blank"
            rel="noopener noreferrer"
            class="text-[#4a4a6a] hover:text-[#00d4ff] transition-colors"
            aria-label="Live demo"
            onclick="event.stopPropagation()"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
              <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/>
              <polyline points="15 3 21 3 21 9"/>
              <line x1="10" y1="14" x2="21" y2="3"/>
            </svg>
          </a>
        )}
      </div>
    </div>

    <!-- Description -->
    <p class="text-[#94a3b8] text-sm leading-relaxed mb-5">
      {description}
    </p>

    <!-- Tech tags -->
    <div class="flex flex-wrap gap-1.5">
      {tags.map(tag => (
        <span class="tag-pill">{tag}</span>
      ))}
    </div>
  </div>

  <!-- Hover bottom border -->
  <div
    class="h-px w-0 group-hover:w-full transition-all duration-300"
    style={`background: linear-gradient(90deg, ${colors.text}, #00d4ff);`}
  ></div>
</div>
