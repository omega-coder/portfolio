---
interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  slug: string;
  readingTime?: number;
}

const { title, description, date, tags, slug, readingTime } = Astro.props;

const formattedDate = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
}).format(date);
---

<article
  class="group block rounded-xl border border-[#2a2a4a] card-hover overflow-hidden"
  style="background: #0f0f1e;"
>
  <a href={`/blog/${slug}`} class="block p-6">
    <!-- Header row -->
    <div class="flex items-start justify-between gap-4 mb-3">
      <h2 class="font-mono font-bold text-[#e2e8f0] text-base leading-tight group-hover:text-[#00ff88] transition-colors line-clamp-2">
        {title}
      </h2>
      <span class="shrink-0 text-[#00ff88] opacity-0 group-hover:opacity-100 transition-opacity font-mono text-sm">
        →
      </span>
    </div>

    <!-- Description -->
    <p class="text-[#94a3b8] text-sm leading-relaxed mb-4 line-clamp-2">
      {description}
    </p>

    <!-- Tags -->
    <div class="flex flex-wrap gap-1.5 mb-4">
      {tags.slice(0, 4).map(tag => (
        <span class="tag-pill">{tag}</span>
      ))}
      {tags.length > 4 && (
        <span class="tag-pill">+{tags.length - 4}</span>
      )}
    </div>

    <!-- Meta -->
    <div class="flex items-center gap-4 text-xs font-mono text-[#4a4a6a]">
      <time datetime={date.toISOString()} class="flex items-center gap-1">
        <span class="text-[#00ff88]">$</span>
        {formattedDate}
      </time>
      {readingTime && (
        <span>~{readingTime} min</span>
      )}
    </div>
  </a>

  <!-- Bottom accent line -->
  <div
    class="h-px w-0 group-hover:w-full transition-all duration-300"
    style="background: linear-gradient(90deg, #00ff88, #00d4ff);"
  ></div>
</article>
