---
import BaseLayout from '../../layouts/BaseLayout.astro';
import WriteupCard from '../../components/WriteupCard.astro';
import { getCollection } from 'astro:content';

const allWriteups = await getCollection('writeups', ({ data }) => !data.draft);
const sortedWriteups = allWriteups.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const allTags = [...new Set(allWriteups.flatMap(w => w.data.tags))].sort();
const allPlatforms = [...new Set(allWriteups.map(w => w.data.platform))].sort();
const allDifficulties = ['Easy', 'Medium', 'Hard', 'Insane'];
---

<BaseLayout
  title="CTF Writeups | Yassine"
  description="CTF writeups covering web, crypto, forensics, and misc challenges from HackTheBox, AngstromCTF, INS'hAck, and more."
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-16">
    <!-- Header -->
    <div class="mb-12">
      <div class="font-mono text-xs text-[#a855f7] mb-2">// cat writeups/index.md</div>
      <h1 class="font-mono text-3xl sm:text-4xl font-bold text-[#e2e8f0] mb-4">CTF Writeups</h1>
      <p class="text-[#94a3b8] max-w-xl">
        Detailed breakdowns of CTF challenges I've solved. Web exploits, crypto attacks, forensics — all documented for the community.
      </p>
    </div>

    <!-- Stats bar -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-10">
      {[
        { label: 'Total Writeups', value: sortedWriteups.length, color: '#00ff88' },
        { label: 'Platforms', value: allPlatforms.length, color: '#00d4ff' },
        { label: 'Categories', value: [...new Set(allWriteups.map(w => w.data.category).filter(Boolean))].length, color: '#fbbf24' },
        { label: 'Tags', value: allTags.length, color: '#a855f7' },
      ].map(stat => (
        <div
          class="rounded-xl border border-[#2a2a4a] p-4 text-center"
          style="background: #0f0f1e;"
        >
          <div class="font-mono font-bold text-2xl mb-1" style={`color: ${stat.color};`}>{stat.value}</div>
          <div class="font-mono text-xs text-[#4a4a6a]">{stat.label}</div>
        </div>
      ))}
    </div>

    <!-- Filters -->
    <div class="space-y-4 mb-8">
      <!-- Search -->
      <div class="relative">
        <span class="absolute left-3 top-1/2 -translate-y-1/2 text-[#4a4a6a] font-mono text-sm">$</span>
        <input
          id="search-input"
          type="text"
          placeholder=" grep -i ..."
          class="w-full pl-8 pr-4 py-2.5 rounded-lg border border-[#2a2a4a] font-mono text-sm text-[#e2e8f0] focus:outline-none focus:border-[#a855f7] transition-colors"
          style="background: #0f0f1e;"
        />
      </div>

      <!-- Platform filter -->
      <div>
        <div class="font-mono text-xs text-[#4a4a6a] mb-2">Platform:</div>
        <div class="flex flex-wrap gap-2">
          <button data-platform="all" class="tag-pill cursor-pointer active">* all</button>
          {allPlatforms.map(p => (
            <button data-platform={p} class="tag-pill cursor-pointer">{p}</button>
          ))}
        </div>
      </div>

      <!-- Difficulty filter -->
      <div>
        <div class="font-mono text-xs text-[#4a4a6a] mb-2">Difficulty:</div>
        <div class="flex flex-wrap gap-2">
          <button data-difficulty="all" class="tag-pill cursor-pointer diff-btn active">* all</button>
          {allDifficulties.map(d => (
            <button
              data-difficulty={d}
              class:list={[
                'cursor-pointer font-mono text-xs px-3 py-1 rounded-full border diff-btn transition-all',
                {
                  'badge-easy': d === 'Easy',
                  'badge-medium': d === 'Medium',
                  'badge-hard': d === 'Hard',
                  'badge-insane': d === 'Insane',
                },
              ]}
            >{d}</button>
          ))}
        </div>
      </div>
    </div>

    <!-- Count -->
    <div class="font-mono text-xs text-[#4a4a6a] mb-6" id="writeup-count">
      {sortedWriteups.length} writeups found
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5" id="writeups-grid">
      {sortedWriteups.map(writeup => (
        <div
          class="writeup-item"
          data-title={writeup.data.title.toLowerCase()}
          data-desc={writeup.data.description.toLowerCase()}
          data-tags={writeup.data.tags.join(',')}
          data-platform={writeup.data.platform}
          data-difficulty={writeup.data.difficulty ?? ''}
        >
          <WriteupCard
            title={writeup.data.title}
            description={writeup.data.description}
            date={writeup.data.date}
            tags={writeup.data.tags}
            slug={writeup.id}
            platform={writeup.data.platform}
            difficulty={writeup.data.difficulty}
            category={writeup.data.category}
            points={writeup.data.points}
          />
        </div>
      ))}
    </div>

    <!-- Empty state -->
    <div id="empty-state" class="hidden text-center py-20">
      <div class="font-mono text-sm">
        <span class="text-[#a855f7]">$</span>
        <span class="text-[#94a3b8]"> find writeups/ -match "query" → No matches</span>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const platformBtns = document.querySelectorAll('[data-platform]');
  const diffBtns = document.querySelectorAll('[data-difficulty]');
  const items = document.querySelectorAll('.writeup-item');
  const countEl = document.getElementById('writeup-count');
  const emptyState = document.getElementById('empty-state');

  let activePlatform = 'all';
  let activeDiff = 'all';
  let query = '';

  function filter() {
    let visible = 0;
    items.forEach(item => {
      const title = item.getAttribute('data-title') ?? '';
      const desc = item.getAttribute('data-desc') ?? '';
      const tags = item.getAttribute('data-tags') ?? '';
      const platform = item.getAttribute('data-platform') ?? '';
      const difficulty = item.getAttribute('data-difficulty') ?? '';

      const matchSearch = !query || title.includes(query) || desc.includes(query) || tags.includes(query);
      const matchPlatform = activePlatform === 'all' || platform === activePlatform;
      const matchDiff = activeDiff === 'all' || difficulty === activeDiff;

      const show = matchSearch && matchPlatform && matchDiff;
      (item as HTMLElement).style.display = show ? '' : 'none';
      if (show) visible++;
    });
    if (countEl) countEl.textContent = `${visible} writeup${visible !== 1 ? 's' : ''} found`;
    emptyState?.classList.toggle('hidden', visible > 0);
  }

  searchInput?.addEventListener('input', e => {
    query = (e.target as HTMLInputElement).value.toLowerCase().trim();
    filter();
  });

  platformBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      activePlatform = btn.getAttribute('data-platform') ?? 'all';
      platformBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      filter();
    });
  });

  diffBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      activeDiff = btn.getAttribute('data-difficulty') ?? 'all';
      diffBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      filter();
    });
  });
</script>
