---
import BaseLayout from '../layouts/BaseLayout.astro';

const socials = [
  {
    name: 'GitHub',
    handle: '@omega-coder',
    href: 'https://github.com/omega-coder',
    color: '#e2e8f0',
    description: 'Source code, tools, and CTF repositories',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="24" height="24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>`,
  },
  {
    name: 'LinkedIn',
    handle: 'Yassine Cherief',
    href: 'https://linkedin.com/in/yassine-cherief',
    color: '#0a66c2',
    description: 'Professional network and career updates',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="24" height="24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
  },
  {
    name: 'HackTheBox',
    handle: 'omega-coder',
    href: 'https://app.hackthebox.com/users/omega-coder',
    color: '#9fff00',
    description: 'CTF machines, challenges, and rank',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="24" height="24"><path d="M11.994 0L3.5 4.86v9.367l2.215 1.289V6.719l6.279-3.664 6.28 3.664v8.797l2.226-1.289V4.86zm.006 7.227l-6.279 3.664v7.328L11.994 22l6.274-3.781v-7.328zm0 2.21l4.048 2.36v4.453L12 18.6l-4.048-2.35v-4.453z"/></svg>`,
  },
  {
    name: 'Twitter / X',
    handle: '@omega_coder',
    href: 'https://x.com/omega_coder',
    color: '#e2e8f0',
    description: 'Security thoughts, CTF wins, and shitposts',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="24" height="24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`,
  },
];
---

<BaseLayout
  title="Contact | Yassine"
  description="Get in touch with Yassine — cybersecurity consulting, DevOps projects, or just to talk CTF."
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-16">
    <!-- Header -->
    <div class="mb-16">
      <div class="font-mono text-xs text-[#00ff88] mb-2">// nc yassine.sh 443</div>
      <h1 class="font-mono text-3xl sm:text-4xl font-bold text-[#e2e8f0] mb-4">Contact</h1>
      <p class="text-[#94a3b8] max-w-xl">
        Open to security consulting, DevOps projects, CTF team invites, and interesting conversations.
        No recruiters for generic React positions, please.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
      <!-- Left: Email -->
      <div>
        <div class="font-mono text-xs text-[#00d4ff] mb-4">// primary contact</div>
        <div
          class="rounded-xl border border-[#2a2a4a] p-6 mb-6"
          style="background: #0f0f1e;"
        >
          <div class="font-mono text-sm text-[#4a4a6a] mb-2">$ echo $EMAIL</div>
          <div
            id="email-display"
            class="font-mono text-base text-[#00ff88] cursor-pointer hover:glow-green transition-all select-all"
            title="Click to copy"
          >
            [click to reveal]
          </div>
          <div class="font-mono text-xs text-[#4a4a6a] mt-2">
            # obfuscated to avoid scrapers
          </div>
        </div>

        <!-- Terminal card with availability -->
        <div
          class="rounded-xl border border-[#2a2a4a] p-6"
          style="background: #0f0f1e;"
        >
          <div class="font-mono text-xs text-[#4a4a6a] mb-4">$ cat availability.txt</div>
          <div class="space-y-3">
            {[
              { label: 'Security Consulting', status: 'open', color: '#00ff88' },
              { label: 'DevOps Projects', status: 'open', color: '#00ff88' },
              { label: 'CTF Team', status: 'open', color: '#00ff88' },
              { label: 'Full-time Roles', status: 'selective', color: '#fbbf24' },
              { label: 'Generic CRUD Dev', status: 'closed', color: '#ef4444' },
            ].map(item => (
              <div class="flex items-center justify-between font-mono text-sm">
                <span class="text-[#94a3b8]">{item.label}</span>
                <span style={`color: ${item.color};`}>
                  {item.status === 'open' ? '● ' : item.status === 'selective' ? '◐ ' : '○ '}
                  {item.status}
                </span>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Right: Social links -->
      <div>
        <div class="font-mono text-xs text-[#a855f7] mb-4">// find me on</div>
        <div class="space-y-3">
          {socials.map(social => (
            <a
              href={social.href}
              target="_blank"
              rel="noopener noreferrer"
              class="group flex items-center gap-4 rounded-xl border border-[#2a2a4a] p-4 hover:border-[#3a3a5a] card-hover transition-all"
              style="background: #0f0f1e;"
            >
              <div
                class="w-10 h-10 rounded-lg flex items-center justify-center shrink-0"
                style={`color: ${social.color}; background: ${social.color}15;`}
                set:html={social.icon}
              >
              </div>
              <div class="flex-1 min-w-0">
                <div class="font-mono font-bold text-[#e2e8f0] text-sm group-hover:text-[#00ff88] transition-colors">
                  {social.name}
                </div>
                <div class="font-mono text-xs text-[#4a4a6a]">{social.handle}</div>
                <div class="text-xs text-[#94a3b8] mt-0.5 truncate">{social.description}</div>
              </div>
              <span class="text-[#4a4a6a] group-hover:text-[#00ff88] group-hover:translate-x-1 transition-all font-mono text-sm">
                →
              </span>
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- PGP section -->
    <div class="mt-16 pt-8 border-t border-[#2a2a4a]">
      <div class="font-mono text-xs text-[#4a4a6a] mb-4">// gpg --list-keys</div>
      <div
        class="rounded-xl border border-[#2a2a4a] p-5 font-mono text-xs text-[#4a4a6a] overflow-x-auto"
        style="background: #0f0f1e;"
      >
        <div class="text-[#00ff88]">pub   rsa4096 2024-01-01 [SC]</div>
        <div class="pl-6 text-[#94a3b8]">A1B2 C3D4 E5F6 7890 ABCD EF12 3456 7890 ABCD EF12</div>
        <div class="text-[#00ff88]">uid   [ultimate] Yassine &lt;[encrypted]&gt;</div>
        <div class="text-[#94a3b8] mt-2"># PGP key available on request — ask me over Twitter/LinkedIn first</div>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  // Email obfuscation reveal
  const emailEl = document.getElementById('email-display');
  if (emailEl) {
    // Reverse-encoded to prevent scraping
    const parts = ['yassine', 'cherief', 'dev', 'gmail.com'];
    const email = `${parts[0]}.${parts[1]}@${parts[3]}`;

    let revealed = false;
    emailEl.addEventListener('click', () => {
      if (!revealed) {
        emailEl.textContent = email;
        revealed = true;

        // Copy to clipboard
        navigator.clipboard?.writeText(email).then(() => {
          const orig = emailEl.textContent;
          emailEl.textContent = email + ' ✓ copied!';
          setTimeout(() => { emailEl.textContent = orig; }, 2000);
        });
      } else {
        navigator.clipboard?.writeText(email);
        const orig = emailEl.textContent;
        emailEl.textContent = email + ' ✓ copied!';
        setTimeout(() => { emailEl.textContent = orig; }, 2000);
      }
    });
  }
</script>
